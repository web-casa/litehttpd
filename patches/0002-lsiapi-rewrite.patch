+    /* litehttpd: Rewrite engine LSIAPI extensions */
+    pApi->parse_rewrite_rules = [](const char *rules_text,
+                                    int text_len) -> void * {
+        if (!rules_text || text_len <= 0)
+        if (text_len > 1024 * 1024) return NULL; /* 1MB max */
+            return NULL;
+        char *buf = (char *)malloc(text_len + 1);
+        if (!buf) return NULL;
+        memcpy(buf, rules_text, text_len);
+        buf[text_len] = 0x00;
+
+        /* Create a temporary HttpContext for parseRules.
+         * parseRules needs context for RewriteEngine On/Off and
+         * RewriteBase — we provide a throwaway context. */
+        HttpContext tmpCtx;
+        RewriteRuleList *pList = new RewriteRuleList();
+        char *p = buf;
+        if (RewriteEngine::parseRules(p, pList, NULL, &tmpCtx) == 0
+            && pList->begin()) {
+            free(buf);
+            return (void *)pList;
+        }
+        delete pList;
+        free(buf);
+        return NULL;
+    };
+
+    pApi->exec_rewrite_rules = [](const lsi_session_t *session,
+                                   void *handle,
+                                   const char *base,
+                                   int base_len) -> int {
+        if (!session || !handle)
+            return -1;
+        HttpSession *pSession = (HttpSession *)session;
+        HttpReq *pReq = pSession->getReq();
+        if (!pReq) return -1;
+        RewriteRuleList *pList = (RewriteRuleList *)handle;
+
+        /* Get context from the current request */
+        const HttpContext *pCtx = pReq->getContext();
+        if (!pCtx) return -1;
+
+        /* processRuleSet returns:
+         *   -3  = URL rewritten internally
+         *    0  = redirect set on pReq (or no match)
+         *  403  = forbidden
+         *  410  = gone
+         *  500  = error
+         * For redirect, it returns 0 but sets REWRITE_REDIR on pReq */
+        RewriteEngine &rwe = RewriteEngine::getInstance();
+        int ret = rwe.processRuleSet(
+            pList, pSession, pCtx, pCtx);
+
+        if (ret == -3) {
+            /* Internal rewrite — call postRewriteProcess */
+            pReq->postRewriteProcess(
+                rwe.getResultURI(),
+                rwe.getResultURILen());
+            return 1;
+        }
+        if (ret == SC_403 || ret == SC_410 || ret == SC_500) {
+            int httpCode = HttpStatusCode::getInstance().indexToCode(ret);
+            if (httpCode <= 0) httpCode = 403;
+            g_lsiapi.set_status_code(session, httpCode);
+            g_lsiapi.end_resp(session);
+            return httpCode;
+        }
+        /* Check if redirect was set on pReq */
+        if (pReq->getContextState(REWRITE_REDIR)) {
+            int sc = rwe.getStatusCode();
+            if (sc < SC_301 || sc >= SC_400)
+                sc = SC_302;
+            int httpCode = HttpStatusCode::getInstance().indexToCode(sc);
+            if (httpCode < 300 || httpCode >= 400) httpCode = 302;
+
+            /* OLS rewrite engine already set Location via setRewriteLocation.
+             * Just set status code and end response to prevent 404 fallthrough. */
+            g_lsiapi.set_status_code(session, httpCode);
+            g_lsiapi.end_resp(session);
+            return httpCode;
+        }
+        return 0;      /* No match */
+    };
+
+    pApi->free_rewrite_rules = [](void *handle) {
+        if (handle)
+            delete (RewriteRuleList *)handle;
+    };
+
     g_lsiapi_ts = g_lsiapi;
 
     pApi = &g_lsiapi_ts;
