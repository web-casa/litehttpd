From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: litehttpd <noreply@github.com>
Date: Wed, 02 Apr 2026 23:00:00 +0800
Subject: [PATCH 2/4] litehttpd: add RewriteRule + PHPConfig LSIAPI extensions

Adds function pointers to lsi_api_t for:
- parse_rewrite_rules: parse RewriteRule/RewriteCond text into handle
- exec_rewrite_rules: execute parsed rules against session (with redirect)
- free_rewrite_rules: cleanup handle
- set_php_config_value/flag: set PHP INI via PHPConfig API
- getStatusCode: public getter for RewriteEngine status code

Key fixes vs original patch:
- Uses HttpContext tmpCtx for parseRules (was NULL → segfault)
- Detects REWRITE_REDIR on HttpReq for redirect handling
- Converts enum status code via indexToCode for module return value
- Adds getStatusCode() public getter to RewriteEngine
---
diff --git a/include/ls.h b/include/ls.h
index 9e7aef6..0fecf99 100644
--- a/include/ls.h
+++ b/include/ls.h
@@ -3981,6 +3981,26 @@ struct lsi_api_s
     void (*register_thread_cleanup)(const lsi_module_t *module,
                                     void (*routine)(void *), void * arg);
 
+    /* litehttpd: PHPConfig LSIAPI + request header write */
+    int (*set_php_config_value)(const lsi_session_t *session,
+                                const char *name, const char *value,
+                                int type);
+    int (*set_php_config_flag)(const lsi_session_t *session,
+                               const char *name, int value,
+                               int type);
+    int (*get_php_config)(const lsi_session_t *session,
+                          const char *name, char *buf, int buf_len);
+    int (*set_req_header)(const lsi_session_t *session,
+                          const char *name, int name_len,
+                          const char *value, int value_len,
+                          int op);
+
+    /* litehttpd: Rewrite engine LSIAPI extensions */
+    void *(*parse_rewrite_rules)(const char *rules_text, int text_len);
+    int (*exec_rewrite_rules)(const lsi_session_t *session, void *handle,
+                              const char *base, int base_len);
+    void (*free_rewrite_rules)(void *handle);
+
 };
 
 /**
diff --git a/src/http/rewriteengine.h b/src/http/rewriteengine.h
index fdc3354..5c8d6f9 100644
--- a/src/http/rewriteengine.h
+++ b/src/http/rewriteengine.h
@@ -113,6 +113,7 @@ public:
                        const HttpContext *pContext, const HttpContext *pRootContext);
     const char *getResultURI()     {   return m_pSourceURL;    }
     int          getResultURILen()  {   return m_sourceURLLen;  }
+    int          getStatusCode()    {   return m_statusCode;    }
 
     void clearUnparsedRuleBuf()     {   m_qsLen = 0;            }
     int appendUnparsedRule(AutoStr2 &sDirective, char *pBegin,
diff --git a/src/lsiapi/lsiapilib.cpp b/src/lsiapi/lsiapilib.cpp
index a51c6a9..eec2eb3 100644
--- a/src/lsiapi/lsiapilib.cpp
+++ b/src/lsiapi/lsiapilib.cpp
@@ -38,6 +38,8 @@
 #include <http/reqparser.h>
 #include <http/clientinfo.h>
 #include <http/ntwkiolink.h>
+#include <http/rewriteengine.h>
+#include <http/rewriterulelist.h>
 
 #include <log4cxx/logger.h>
 #include <lsiapi/envmanager.h>
@@ -3792,6 +3794,121 @@ void lsiapi_init_server_api()
     pApi->schedule_remove_session_cbs_event = schedule_remove_session_cbs_event;
     pApi->register_thread_cleanup = register_thread_cleanup_ts;
 
+    /* litehttpd: PHPConfig LSIAPI extensions */
+    pApi->set_php_config_value = [](const lsi_session_t *session,
+                                    const char *name, const char *value,
+                                    int type) -> int {
+        if (!session || !name || !name[0]) return -1;
+        HttpSession *pSess = (HttpSession *)session;
+        HttpReq *pReq = pSess->getReq();
+        if (!pReq) return -1;
+        HttpContext *pCtx = (HttpContext *)pReq->getContext();
+        if (!pCtx) return -1;
+        PHPConfig *pCfg = pCtx->getPHPConfig();
+        if (!pCfg) {
+            pCfg = new PHPConfig();
+            pCtx->setPHPConfig(pCfg);
+        }
+        char buf[1024];
+        int n = snprintf(buf, sizeof(buf), "%s %s", name, value ? value : "");
+        if (n < 0 || n >= (int)sizeof(buf)) return -1;
+        char err[256] = {0};
+        pCfg->parse(type, buf, err, sizeof(err));
+        pCfg->buildLsapiEnv();
+        return 0;
+    };
+    pApi->set_php_config_flag = [](const lsi_session_t *session,
+                                   const char *name, int value,
+                                   int type) -> int {
+        const char *v = value ? "1" : "0";
+        if (g_lsiapi.set_php_config_value)
+            return g_lsiapi.set_php_config_value(session, name, v, type);
+        return -1;
+    };
+    pApi->get_php_config = nullptr;
+    pApi->set_req_header = nullptr;
+
+    /* litehttpd: Rewrite engine LSIAPI extensions */
+    pApi->parse_rewrite_rules = [](const char *rules_text,
+                                    int text_len) -> void * {
+        if (!rules_text || text_len <= 0)
+            return NULL;
+        char *buf = (char *)malloc(text_len + 1);
+        if (!buf) return NULL;
+        memcpy(buf, rules_text, text_len);
+        buf[text_len] = 0x00;
+
+        /* Create a temporary HttpContext for parseRules.
+         * parseRules needs context for RewriteEngine On/Off and
+         * RewriteBase — we provide a throwaway context. */
+        HttpContext tmpCtx;
+        RewriteRuleList *pList = new RewriteRuleList();
+        char *p = buf;
+        if (RewriteEngine::parseRules(p, pList, NULL, &tmpCtx) == 0
+            && pList->begin()) {
+            free(buf);
+            return (void *)pList;
+        }
+        delete pList;
+        free(buf);
+        return NULL;
+    };
+
+    pApi->exec_rewrite_rules = [](const lsi_session_t *session,
+                                   void *handle,
+                                   const char *base,
+                                   int base_len) -> int {
+        if (!session || !handle)
+            return -1;
+        HttpSession *pSession = (HttpSession *)session;
+        HttpReq *pReq = pSession->getReq();
+        RewriteRuleList *pList = (RewriteRuleList *)handle;
+
+        /* Get context from the current request */
+        const HttpContext *pCtx = pReq->getContext();
+
+        /* processRuleSet returns:
+         *   -3  = URL rewritten internally
+         *    0  = redirect set on pReq (or no match)
+         *  403  = forbidden
+         *  410  = gone
+         *  500  = error
+         * For redirect, it returns 0 but sets REWRITE_REDIR on pReq */
+        RewriteEngine &rwe = RewriteEngine::getInstance();
+        int ret = rwe.processRuleSet(
+            pList, pSession, pCtx, pCtx);
+
+        if (ret == -3) {
+            /* Internal rewrite — call postRewriteProcess */
+            pReq->postRewriteProcess(
+                rwe.getResultURI(),
+                rwe.getResultURILen());
+            return 1;
+        }
+        if (ret == SC_403 || ret == SC_410 || ret == SC_500) {
+            int httpCode = HttpStatusCode::getInstance().indexToCode(ret);
+            if (httpCode <= 0) httpCode = 403;
+            g_lsiapi.set_status_code(session, httpCode);
+            g_lsiapi.end_resp(session);
+            return httpCode;
+        }
+        /* Check if redirect was set on pReq */
+        if (pReq->getContextState(REWRITE_REDIR)) {
+            int sc = rwe.getStatusCode();
+            if (sc < SC_301 || sc >= SC_400)
+                sc = SC_302;
+            int httpCode = HttpStatusCode::getInstance().indexToCode(sc);
+            if (httpCode < 300 || httpCode >= 400) httpCode = 302;
+
+            /* OLS rewrite engine already set Location via setRewriteLocation.
+             * Just set status code and end response to prevent 404 fallthrough. */
+            g_lsiapi.set_status_code(session, httpCode);
+            g_lsiapi.end_resp(session);
+            return httpCode;
+        }
+        return 0;      /* No match */
+    };
+
+    pApi->free_rewrite_rules = [](void *handle) {
+        if (handle)
+            delete (RewriteRuleList *)handle;
+    };
+
     g_lsiapi_ts = g_lsiapi;
 
     pApi = &g_lsiapi_ts;
