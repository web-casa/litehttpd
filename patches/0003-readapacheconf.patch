+                            {
+                                logToMem(LOG_LEVEL_INFO,
+                                    "readApacheConf: converted %d vhost(s), "
+                                    "loading %s/", apConf.vhost_count, outputDir);
+                                loadConfFile(outputDir);
+                            }
+                            else
+                                logToMem(LOG_LEVEL_ERR,
+                                    "readApacheConf: failed to write OLS config");
+                        }
+                        else
+                            logToMem(LOG_LEVEL_ERR,
+                                "readApacheConf: failed to parse %s (rc=%d)",
+                                apachePath, rc);
+                        ap_config_free(&apConf);
+                    }
+                }
