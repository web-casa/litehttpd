+            {
+                /* litehttpd: readApacheConf /path/to/httpd.conf [portmap=X:Y]
+                 * Parses Apache config IN-PROCESS (like LSWS/CyberPanel)
+                 * and writes OLS native config, then loads it. */
+                const char *ra = p + 14;
+                while (*ra == ' ' || *ra == '\t') ra++;
+                if (*ra)
+                {
+                    char apachePath[4096] = {0};
+                    char portmapArg[4096] = {0};
+                    const char *sp = ra;
+                    while (*sp && *sp != ' ' && *sp != '\t') sp++;
+                    size_t pLen = (size_t)(sp - ra);
+                    if (pLen >= sizeof(apachePath)) pLen = sizeof(apachePath) - 1;
+                    memcpy(apachePath, ra, pLen);
+                    while (*sp == ' ' || *sp == '\t') sp++;
+                    if (*sp)
+                        lstrncpy(portmapArg, sp, sizeof(portmapArg));
+
+                    char outputDir[4096];
+                    snprintf(outputDir, sizeof(outputDir),
+                             "%s/conf/apacheconf", rootPath.c_str());
+
+                    struct stat stBuf;
+                    if (stat(apachePath, &stBuf) != 0)
+                    {
+                        logToMem(LOG_LEVEL_ERR,
+                            "readApacheConf: config not found: %s", apachePath);
+                    }
+                    else
+                    {
+                        logToMem(LOG_LEVEL_INFO,
+                            "readApacheConf: parsing %s (in-process)", apachePath);
+
+                        /* Parse Apache config in-process */
+                        ap_config_t apConf;
+                        memset(&apConf, 0, sizeof(apConf));
+
+                        /* Apply portmap if specified (e.g. portmap=80:8088,443:8443) */
+                        if (strncmp(portmapArg, "portmap=", 8) == 0)
+                        {
+                            const char *pm = portmapArg + 8;
+                            char pmBuf[4096];
+                            lstrncpy(pmBuf, pm, sizeof(pmBuf));
+                            char *tok = strtok(pmBuf, ",");
+                            while (tok && apConf.port_map_count < AP_MAX_PORTMAP)
+                            {
+                                int from = 0, to = 0;
+                                if (sscanf(tok, "%d:%d", &from, &to) == 2
+                                    && from > 0 && to > 0)
+                                {
+                                    apConf.port_from[apConf.port_map_count] = from;
+                                    apConf.port_to[apConf.port_map_count] = to;
+                                    apConf.port_map_count++;
+                                }
+                                tok = strtok(NULL, ",");
+                            }
+                        }
+
+                        int rc = ap_parse_config(apachePath, &apConf);
