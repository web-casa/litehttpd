---
/**
 * Terminal component that simulates LiteHTTPD installation and usage.
 * Displayed in the hero section of the landing page.
 */
---

<div class="terminal">
  <div class="terminal-header">
    <span class="terminal-dot red"></span>
    <span class="terminal-dot yellow"></span>
    <span class="terminal-dot green"></span>
    <span class="terminal-title">terminal</span>
  </div>
  <div class="terminal-body">
    <div class="line"><span class="prompt">$</span> <span class="cmd">cp litehttpd_htaccess.so /usr/local/lsws/modules/</span></div>
    <div class="line"><span class="prompt">$</span> <span class="cmd">echo 'module litehttpd_htaccess {"{"} ls_enabled 1 {"}"}' &gt;&gt; httpd_config.conf</span></div>
    <div class="line"><span class="prompt">$</span> <span class="cmd">lswsctrl restart</span></div>
    <div class="line output">[OK] litespeed: pid=42019.</div>
    <div class="line blank"></div>
    <div class="line"><span class="prompt">$</span> <span class="cmd">curl -I localhost:8088/</span></div>
    <div class="line output">HTTP/1.1 <span class="ok">200 OK</span></div>
    <div class="line output">x-custom-header: <span class="val">LiteHTTPD</span></div>
    <div class="line output">cache-control: <span class="val">max-age=31536000</span></div>
    <div class="line output">x-frame-options: <span class="val">SAMEORIGIN</span></div>
    <div class="line blank"></div>
    <div class="line"><span class="prompt">$</span> <span class="cmd">curl -o /dev/null -w "%{'{'}http_code{'}'}" localhost:8088/.htaccess</span></div>
    <div class="line output"><span class="ok">403</span> <span class="comment"># .htaccess protected</span></div>
  </div>
</div>

<style>
  .terminal {
    background: #0d1117;
    border-radius: 8px;
    overflow: hidden;
    font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    border: 1px solid #30363d;
    max-width: 540px;
    width: 100%;
  }
  .terminal-header {
    background: #161b22;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    border-bottom: 1px solid #30363d;
  }
  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .terminal-dot.red { background: #ff5f56; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green { background: #27c93f; }
  .terminal-title {
    margin-left: 0.5rem;
    color: #8b949e;
    font-size: 0.7rem;
  }
  .terminal-body {
    padding: 0.75rem 1rem;
    color: #c9d1d9;
  }
  .line {
    white-space: nowrap;
    overflow: hidden;
  }
  .line.blank {
    height: 0.75rem;
  }
  .prompt {
    color: #22c55e;
    font-weight: 700;
    margin-right: 0.375rem;
  }
  .cmd {
    color: #e6edf3;
  }
  .output {
    color: #8b949e;
    padding-left: 1rem;
  }
  .ok {
    color: #22c55e;
    font-weight: 600;
  }
  .val {
    color: #79c0ff;
  }
  .comment {
    color: #6e7681;
    font-style: italic;
  }
  @media (max-width: 50rem) {
    .terminal {
      font-size: 0.65rem;
      max-width: 100%;
    }
  }
</style>
