## Stage 1: Build patched OLS from source using its own build.sh
FROM ubuntu:22.04 AS ols-builder

# Install base deps needed by build.sh
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ cmake make wget ca-certificates patch git curl \
    libpcre3-dev libexpat1-dev zlib1g-dev libxml2-dev libaio-dev \
    libssl-dev libudns-dev libcap-dev libmaxminddb-dev \
    golang autoconf libtool pkg-config \
    && rm -rf /var/lib/apt/lists/*

ARG OLS_VERSION=1.8.5
RUN git clone --depth 1 --recurse-submodules --branch v${OLS_VERSION} \
    https://github.com/litespeedtech/openlitespeed.git /tmp/openlitespeed-${OLS_VERSION}

WORKDIR /tmp/openlitespeed-${OLS_VERSION}

# Apply patches
COPY 0001-lsiapi-phpconfig.patch /tmp/
COPY 0002-lsiapi-rewrite.patch /tmp/
COPY 0004-autoindex-403.patch /tmp/
RUN patch -p1 < /tmp/0001-lsiapi-phpconfig.patch && \
    patch -p1 < /tmp/0002-lsiapi-rewrite.patch && \
    patch -p1 < /tmp/0004-autoindex-403.patch

# Use OLS build.sh to handle all deps (BoringSSL, brotli, etc.)
# build.sh may return non-zero if modsecurity module fails, but core binary is ok
RUN bash build.sh || true
RUN ls -la build/src/openlitespeed dist/bin/openlitespeed 2>/dev/null; \
    test -f build/src/openlitespeed && \
    mkdir -p /opt/ols-install/usr/local/lsws/bin && \
    cp build/src/openlitespeed /opt/ols-install/usr/local/lsws/bin/

## Stage 2: Runtime image with patched OLS + module
FROM litespeedtech/openlitespeed:latest

# Replace OLS binary with patched version
COPY --from=ols-builder /opt/ols-install/usr/local/lsws/bin/openlitespeed \
                         /usr/local/lsws/bin/openlitespeed

# Create document root and SHM directory
RUN mkdir -p /var/www/html /dev/shm/ols && \
    chown nobody:nogroup /dev/shm/ols

# Copy the compiled module (placed in build context by run_compare.sh)
COPY litehttpd_htaccess.so /usr/local/lsws/modules/litehttpd_htaccess.so

# Copy shared document root
COPY htdocs/ /var/www/html/

RUN chown -R nobody:nogroup /var/www/html

# Create vhost config directory
RUN mkdir -p /usr/local/lsws/conf/vhosts/compare

COPY conf/vhconf_compare.conf /usr/local/lsws/conf/vhosts/compare/vhconf.conf
COPY conf/httpd_compare_module.conf /tmp/httpd_patch.conf

# Patch httpd_config.conf: add module + listener + vhost
RUN cat /tmp/httpd_patch.conf >> /usr/local/lsws/conf/httpd_config.conf

EXPOSE 8088
