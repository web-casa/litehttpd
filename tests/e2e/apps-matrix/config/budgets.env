# Report-only default budgets for apps-matrix full/heavy runs.
# Tune with:
#   python3 tests/e2e/apps-matrix/lib/tune_budgets.py --out-dir <artifact-dir>
#
# Values are intentionally conservative until enough CI/VPS samples exist.

MATRIX_BUDGET_DEFAULT_INSTALL_MS="${MATRIX_BUDGET_DEFAULT_INSTALL_MS:-2700000}"
MATRIX_BUDGET_DEFAULT_VERIFY_MS="${MATRIX_BUDGET_DEFAULT_VERIFY_MS:-900000}"
MATRIX_BUDGET_DEFAULT_ALL_MS="${MATRIX_BUDGET_DEFAULT_ALL_MS:-5400000}"

MATRIX_BUDGET_WORDPRESS_CORE_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_CORE_INSTALL_MS:-1200000}"
MATRIX_BUDGET_WORDPRESS_CORE_VERIFY_MS="${MATRIX_BUDGET_WORDPRESS_CORE_VERIFY_MS:-900000}"
MATRIX_BUDGET_WORDPRESS_CORE_ALL_MS="${MATRIX_BUDGET_WORDPRESS_CORE_ALL_MS:-2400000}"

MATRIX_BUDGET_WORDPRESS_REDIRECTION_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_REDIRECTION_INSTALL_MS:-1500000}"
MATRIX_BUDGET_WORDPRESS_W3_TOTAL_CACHE_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_W3_TOTAL_CACHE_INSTALL_MS:-1800000}"
MATRIX_BUDGET_WORDPRESS_LITESPEED_CACHE_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_LITESPEED_CACHE_INSTALL_MS:-1800000}"
MATRIX_BUDGET_WORDPRESS_WORDFENCE_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_WORDFENCE_INSTALL_MS:-1800000}"
MATRIX_BUDGET_WORDPRESS_EWWW_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_EWWW_INSTALL_MS:-1800000}"
MATRIX_BUDGET_WORDPRESS_WP_OPTIMIZE_INSTALL_MS="${MATRIX_BUDGET_WORDPRESS_WP_OPTIMIZE_INSTALL_MS:-1800000}"

MATRIX_BUDGET_LARAVEL_INSTALL_MS="${MATRIX_BUDGET_LARAVEL_INSTALL_MS:-1800000}"
MATRIX_BUDGET_DRUPAL_INSTALL_MS="${MATRIX_BUDGET_DRUPAL_INSTALL_MS:-2700000}"
MATRIX_BUDGET_NEXTCLOUD_INSTALL_MS="${MATRIX_BUDGET_NEXTCLOUD_INSTALL_MS:-2700000}"
MATRIX_BUDGET_JOOMLA_INSTALL_MS="${MATRIX_BUDGET_JOOMLA_INSTALL_MS:-1800000}"
MATRIX_BUDGET_MEDIAWIKI_INSTALL_MS="${MATRIX_BUDGET_MEDIAWIKI_INSTALL_MS:-1800000}"
