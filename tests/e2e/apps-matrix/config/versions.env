# Pinned defaults for apps-matrix real fixture installers.
# Override any value in CI or local runs as needed.

MATRIX_WORDPRESS_VERSION="${MATRIX_WORDPRESS_VERSION:-6.9.1}"
MATRIX_WORDPRESS_ADMIN_USER="${MATRIX_WORDPRESS_ADMIN_USER:-admin}"
MATRIX_WORDPRESS_ADMIN_PASSWORD="${MATRIX_WORDPRESS_ADMIN_PASSWORD:-AppsMatrixAdmin123!}"
MATRIX_WORDPRESS_ADMIN_EMAIL="${MATRIX_WORDPRESS_ADMIN_EMAIL:-matrix@example.test}"

MATRIX_DRUPAL_VERSION="${MATRIX_DRUPAL_VERSION:-10.4.*}"
MATRIX_DRUSH_VERSION="${MATRIX_DRUSH_VERSION:-^12}"
MATRIX_LARAVEL_VERSION="${MATRIX_LARAVEL_VERSION:-12.*}"
MATRIX_NEXTCLOUD_VERSION="${MATRIX_NEXTCLOUD_VERSION:-32.0.12}"
MATRIX_JOOMLA_VERSION="${MATRIX_JOOMLA_VERSION:-5.2.3}"
MATRIX_MEDIAWIKI_VERSION="${MATRIX_MEDIAWIKI_VERSION:-1.39.10}"
MATRIX_MEDIAWIKI_MAJOR="${MATRIX_MEDIAWIKI_MAJOR:-1.39}"

MATRIX_PLUGIN_W3TC="${MATRIX_PLUGIN_W3TC:-w3-total-cache}"
MATRIX_PLUGIN_LSCACHE="${MATRIX_PLUGIN_LSCACHE:-litespeed-cache}"
MATRIX_PLUGIN_WORDFENCE="${MATRIX_PLUGIN_WORDFENCE:-wordfence}"
MATRIX_PLUGIN_REDIRECTION="${MATRIX_PLUGIN_REDIRECTION:-redirection}"
MATRIX_PLUGIN_EWWW="${MATRIX_PLUGIN_EWWW:-ewww-image-optimizer}"
MATRIX_PLUGIN_WP_OPTIMIZE="${MATRIX_PLUGIN_WP_OPTIMIZE:-wp-optimize}"

MATRIX_REAL_DB_HOST="${MATRIX_REAL_DB_HOST:-127.0.0.1}"
MATRIX_REAL_DB_PORT="${MATRIX_REAL_DB_PORT:-33306}"
MATRIX_REAL_DB_INSTALL_HOST="${MATRIX_REAL_DB_INSTALL_HOST:-${MATRIX_REAL_DB_HOST}}"
MATRIX_REAL_DB_INSTALL_PORT="${MATRIX_REAL_DB_INSTALL_PORT:-${MATRIX_REAL_DB_PORT}}"
MATRIX_REAL_DB_RUNTIME_HOST="${MATRIX_REAL_DB_RUNTIME_HOST:-${MATRIX_REAL_DB_HOST}}"
MATRIX_REAL_DB_RUNTIME_PORT="${MATRIX_REAL_DB_RUNTIME_PORT:-${MATRIX_REAL_DB_PORT}}"
MATRIX_REAL_DB_ROOT_USER="${MATRIX_REAL_DB_ROOT_USER:-root}"
MATRIX_REAL_DB_ROOT_PASSWORD="${MATRIX_REAL_DB_ROOT_PASSWORD:-rootpass}"
MATRIX_REAL_DB_USER="${MATRIX_REAL_DB_USER:-matrix}"
MATRIX_REAL_DB_PASSWORD="${MATRIX_REAL_DB_PASSWORD:-matrixpass}"
