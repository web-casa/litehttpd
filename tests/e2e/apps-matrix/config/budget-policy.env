# Release-facing apps-matrix budget policy.
#
# This release keeps timing budgets advisory until enough representative
# CI/DO samples exist. Switch APPS_MATRIX_BUDGET_POLICY_MODE to "enforced"
# and APPS_MATRIX_BUDGET_ALLOW_ENFORCEMENT to 1 only after the ratchet check
# passes with the required scenario/phase sample counts and budgets.env has
# been updated from p95 data.

APPS_MATRIX_BUDGET_POLICY_MODE="${APPS_MATRIX_BUDGET_POLICY_MODE:-advisory}"
APPS_MATRIX_BUDGET_ALLOW_ENFORCEMENT="${APPS_MATRIX_BUDGET_ALLOW_ENFORCEMENT:-0}"
APPS_MATRIX_BUDGET_REQUIRED_MIN_SAMPLES="${APPS_MATRIX_BUDGET_REQUIRED_MIN_SAMPLES:-5}"
APPS_MATRIX_BUDGET_REQUIRED_SCENARIOS="${APPS_MATRIX_BUDGET_REQUIRED_SCENARIOS:-heavy}"
APPS_MATRIX_BUDGET_REQUIRED_PHASES="${APPS_MATRIX_BUDGET_REQUIRED_PHASES:-all}"
